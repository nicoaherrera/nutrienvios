# Variables de entorno del backend (Vercel > Settings > Environment Variables).
# NUNCA usar prefijo VITE_ acá: estas claves solo viven en las funciones serverless.

# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NO la anon key)

# Tokens de acceso de la app (inventar dos strings largos y distintos)
TOKEN_TIENDA=cambiame-token-tienda
TOKEN_REPARTIDOR=cambiame-token-repartidor
